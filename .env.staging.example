# ─────────────────────────────────────────────
# Staging environment — Visiblee
#
# Copy this file to apps/web/.env (Next.js) and services/analyzer/.env (Python)
# for the staging environment (branch: dev, domain: dev.visiblee.ai).
#
# The staging database is `visiblee_dev` — separate from `visiblee` (production).
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Database (staging)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@<hetzner-db-host>:5432/visiblee_dev

# ─────────────────────────────────────────────
# Auth (Auth.js v5 / NextAuth)
# ─────────────────────────────────────────────
NEXTAUTH_URL=https://dev.visiblee.ai
AUTH_SECRET=<generate with: openssl rand -base64 32>

# Google OAuth — use the same credentials as production
# Add https://dev.visiblee.ai/api/auth/callback/google as an authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# App URL (used for links in emails)
# ─────────────────────────────────────────────
APP_URL=https://dev.visiblee.ai

# ─────────────────────────────────────────────
# Python microservice
# ─────────────────────────────────────────────
ANALYZER_API_URL=http://<hetzner-python-host>:8000
ANALYZER_API_KEY=<staging-internal-key — must match services/analyzer/.env>

# ─────────────────────────────────────────────
# LLM providers
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
VOYAGE_API_KEY=

# ─────────────────────────────────────────────
# Search API
# ─────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ─────────────────────────────────────────────
# Email (MailerSend)
# ─────────────────────────────────────────────
MAILERSEND_API_KEY=
EMAIL_FROM=noreply@visiblee.ai

# ─────────────────────────────────────────────
# Google Search Console integration
# ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must match GSC_TOKEN_ENCRYPTION_KEY in services/analyzer/.env
GSC_TOKEN_ENCRYPTION_KEY=
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
NEXT_PUBLIC_GSC_ENABLED=true

# ─────────────────────────────────────────────
# Analytics (disabled on staging)
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
