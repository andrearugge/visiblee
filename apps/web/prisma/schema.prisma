// Visiblee — Prisma schema
// Database: PostgreSQL + pgvector
// Vector columns use Unsupported("vector(1024)") — pgvector extension
// enabled via raw SQL in the initial migration.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String?
  avatarUrl         String?
  hashedPassword    String?
  role              String    @default("user") // 'user' | 'admin' | 'superadmin'
  preferredLocale   String    @default("en")   // 'en' | 'it'
  emailVerified     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  projects        Project[]
  notifications   Notification[]
  previewAnalyses PreviewAnalysis[]
  gscConnections  GscConnection[]

  @@map("users")
}

// Auth.js v5 adapter tables
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// PREVIEW ANALYSES
// ─────────────────────────────────────────────

model PreviewAnalysis {
  id         String   @id @default(uuid())

  // Data from landing page form
  websiteUrl   String
  brandName    String
  queryTargets String[]

  // Micro-analysis results (v2 score names)
  aiReadinessScore    Float?
  fanoutCoverageScore Float?
  citationPowerScore  Float?
  extractabilityScore Float?
  entityAuthorityScore Float?
  sourceAuthorityScore Float?
  insights             Json?
  contentsFound        Int?
  analysisData         Json?

  // Post-registration link
  userId      String?
  projectId   String?
  convertedAt DateTime?

  // Lead capture
  reportEmail  String?
  reportSentAt DateTime?

  // Tracking
  ipAddress  String?
  userAgent  String?
  referrer   String?
  locale     String?

  // Status
  status    String   @default("pending") // 'pending' | 'processing' | 'completed' | 'failed'
  createdAt DateTime @default(now())
  expiresAt DateTime @default(dbgenerated("NOW() + INTERVAL '30 days'"))

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  jobs    Job[]

  @@index([status])
  @@index([userId])
  @@index([reportEmail])
  @@map("preview_analyses")
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id                String  @id @default(uuid())
  userId            String
  name              String
  description       String?
  brandName         String
  websiteUrl        String
  brandContext      String?
  previewId         String?
  status            String  @default("active") // 'active' | 'paused' | 'archived'
  optimizationFocus String? // 'content_quality' | 'brand_authority' | 'cross_platform' | 'technical'
  aiPlatformTarget  String  @default("all")    // 'google_ai' | 'chatgpt' | 'perplexity' | 'all'
  targetLanguage    String  @default("en")     // ISO 639-1: 'it' | 'en' | 'es' | 'fr' | 'de' | 'pt'
  targetCountry     String  @default("US")     // ISO 3166-1 alpha-2: country of the target market
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetQueries     TargetQuery[]
  contents          Content[]
  competitors       Competitor[]
  scoreSnapshots    ProjectScoreSnapshot[]
  recommendations   Recommendation[]
  notifications     Notification[]
  jobs              Job[]
  previewAnalyses   PreviewAnalysis[]
  citationChecks    CitationCheck[]
  gscConnection     GscConnection?
  gscQueryData      GscQueryData[]
  intentProfiles    IntentProfile[]
  querySuggestions  GscQuerySuggestion[]

  @@index([userId])
  @@map("projects")
}

// ─────────────────────────────────────────────
// QUERIES
// ─────────────────────────────────────────────

model TargetQuery {
  id        String  @id @default(uuid())
  projectId String
  queryText String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fanoutQueries      FanoutQuery[]
  competitorContents CompetitorContent[]
  citationChecks     CitationCheck[]

  @@index([projectId])
  @@map("target_queries")
}

model FanoutQuery {
  id            String   @id @default(uuid())
  targetQueryId String
  queryText     String
  queryType     String   // 'related' | 'implicit' | 'comparative' | 'exploratory' | 'decisional' | 'recent'
  embedding     Unsupported("vector(1024)")?
  generatedAt   DateTime @default(now())
  batchId       String

  targetQuery   TargetQuery          @relation(fields: [targetQueryId], references: [id], onDelete: Cascade)
  coverageMap   FanoutCoverageMap[]

  @@index([targetQueryId])
  @@index([batchId])
  @@map("fanout_queries")
}

// ─────────────────────────────────────────────
// CONTENTS
// ─────────────────────────────────────────────

model Content {
  id                  String   @id @default(uuid())
  projectId           String
  url                 String
  title               String?
  platform            String   // 'website' | 'linkedin' | 'medium' | 'substack' | 'reddit' | 'youtube' | 'news' | 'other'
  contentType         String   @default("own")       // 'own' | 'mention'
  source              String   @default("discovery") // 'discovery' | 'manual'
  isIndexed           Boolean  @default(true)
  isConfirmed         Boolean  @default(false)
  rawText             String?
  rawHtml             String?
  wordCount           Int?
  lastFetchedAt       DateTime?
  lastModifiedAt      DateTime?
  discoveryConfidence Float?
  schemaMarkup        Json?
  hasArticleSchema    Boolean  @default(false)
  hasFaqSchema        Boolean  @default(false)
  hasOrgSchema        Boolean  @default(false)
  dateModifiedSchema  DateTime?
  lastContentHash     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  passages        Passage[]
  contentScores   ContentScore[]
  recommendations Recommendation[]
  versions        ContentVersion[]

  @@unique([url, projectId])
  @@index([projectId])
  @@index([platform])
  @@map("contents")
}

model Passage {
  id               String   @id @default(uuid())
  contentId        String
  passageText      String
  passageIndex     Int
  wordCount        Int?
  heading          String?
  embedding        Unsupported("vector(1024)")?
  relativePosition Float?
  entityDensity    Float?
  hasStatistics    Boolean  @default(false)
  hasSourceCitation Boolean @default(false)
  isAnswerFirst    Boolean  @default(false)
  createdAt        DateTime @default(now())

  content         Content            @relation(fields: [contentId], references: [id], onDelete: Cascade)
  passageScores   PassageScore[]
  coverageMap     FanoutCoverageMap[]
  weakestForContentScores ContentScore[] @relation("WeakestPassage")
  recommendations Recommendation[]

  @@index([contentId])
  @@map("passages")
}

// ─────────────────────────────────────────────
// COMPETITORS
// ─────────────────────────────────────────────

model Competitor {
  id               String  @id @default(uuid())
  projectId        String
  name             String
  websiteUrl       String?
  source           String  @default("auto") // 'auto' | 'manual'
  isConfirmed      Boolean @default(false)
  avgPassageScore  Float?
  createdAt        DateTime @default(now())

  project  Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contents CompetitorContent[]

  @@index([projectId])
  @@map("competitors")
}

model CompetitorContent {
  id              String  @id @default(uuid())
  competitorId    String
  url             String
  title           String?
  rawText         String?
  foundForQueryId String?
  createdAt       DateTime @default(now())

  competitor    Competitor         @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  foundForQuery TargetQuery?       @relation(fields: [foundForQueryId], references: [id])
  passages      CompetitorPassage[]

  @@map("competitor_contents")
}

model CompetitorPassage {
  id                  String   @id @default(uuid())
  competitorContentId String
  passageText         String
  passageIndex        Int
  wordCount           Int?
  overallScore        Float?
  embedding           Unsupported("vector(1024)")?
  createdAt           DateTime @default(now())

  competitorContent CompetitorContent @relation(fields: [competitorContentId], references: [id], onDelete: Cascade)

  @@map("competitor_passages")
}

// ─────────────────────────────────────────────
// SCORING
// ─────────────────────────────────────────────

model ProjectScoreSnapshot {
  id                   String   @id @default(uuid())
  projectId            String
  snapshotType         String   @default("weekly") // 'weekly' | 'manual'
  aiReadinessScore     Float
  fanoutCoverageScore  Float
  citationPowerScore   Float
  extractabilityScore  Float
  entityAuthorityScore Float
  sourceAuthorityScore Float
  metadata             Json?
  createdAt            DateTime @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentScores   ContentScore[]
  passageScores   PassageScore[]
  recommendations Recommendation[]
  citationChecks  CitationCheck[]
  contentVersions ContentVersion[]

  @@index([projectId])
  @@map("project_score_snapshots")
}

model ContentScore {
  id                  String   @id @default(uuid())
  contentId           String
  snapshotId          String
  overallScore        Float
  citationPowerScore  Float?
  extractabilityScore Float?
  fanoutCoverageScore Float?
  weakestPassageId    String?
  details             Json?
  createdAt           DateTime @default(now())

  content        Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)
  snapshot       ProjectScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  weakestPassage Passage?             @relation("WeakestPassage", fields: [weakestPassageId], references: [id])

  @@index([contentId])
  @@index([snapshotId])
  @@map("content_scores")
}

model PassageScore {
  id                     String   @id @default(uuid())
  passageId              String
  snapshotId             String
  positionScore          Float?
  entityDensity          Float?
  statisticalSpecificity Float?
  definiteness           Float?
  answerFirst            Float?
  sourceCitation         Float?
  overallScore           Float?
  llmReasoning           String?
  createdAt              DateTime @default(now())

  passage  Passage              @relation(fields: [passageId], references: [id], onDelete: Cascade)
  snapshot ProjectScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([passageId])
  @@index([snapshotId])
  @@map("passage_scores")
}

model FanoutCoverageMap {
  id              String   @id @default(uuid())
  fanoutQueryId   String
  passageId       String
  similarityScore Float
  isCovered       Boolean
  coverageTier    String?  // 'excellent' | 'good' | 'weak' | 'none'
  createdAt       DateTime @default(now())

  fanoutQuery FanoutQuery @relation(fields: [fanoutQueryId], references: [id], onDelete: Cascade)
  passage     Passage     @relation(fields: [passageId], references: [id], onDelete: Cascade)

  @@index([fanoutQueryId])
  @@index([passageId])
  @@map("fanout_coverage_map")
}

// ─────────────────────────────────────────────
// CITATION VERIFICATION
// ─────────────────────────────────────────────

model CitationCheck {
  id                String   @id @default(uuid())
  projectId         String
  targetQueryId     String
  snapshotId        String?
  citedSources      Json     // [{url, title, domain, isUser, isCompetitor, position, supportedText}]
  userCited         Boolean  @default(false)
  userCitedPosition Int?     // 1-based position if cited
  userCitedSegment  String?  // AI response segment supported by user's content
  responseText      String?  // full synthesized AI response
  searchQueries     Json?    // Gemini's internal fan-out queries (real signal)
  rawResponse       String?  // full response for debug
  checkedAt         DateTime @default(now())

  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetQuery TargetQuery           @relation(fields: [targetQueryId], references: [id], onDelete: Cascade)
  snapshot    ProjectScoreSnapshot? @relation(fields: [snapshotId], references: [id])
  variants    CitationCheckVariant[]

  @@index([projectId])
  @@index([targetQueryId])
  @@map("citation_checks")
}

model ContentVersion {
  id          String   @id @default(uuid())
  contentId   String
  snapshotId  String
  passageData Json     // snapshot dei passaggi con score al momento dell'analisi
  contentHash String   // hash per detect cambiamenti
  createdAt   DateTime @default(now())

  content  Content              @relation(fields: [contentId], references: [id], onDelete: Cascade)
  snapshot ProjectScoreSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@map("content_versions")
}

// ─────────────────────────────────────────────
// RECOMMENDATIONS
// ─────────────────────────────────────────────

model Recommendation {
  id              String   @id @default(uuid())
  projectId       String
  contentId       String?
  passageId       String?
  type            String   // 'quick_win' | 'content_gap' | 'platform_opportunity'
  priority        String   @default("medium") // 'high' | 'medium' | 'low'
  effort          String?  // 'quick' | 'moderate' | 'significant'
  title           String
  description     String
  suggestedAction String?
  estimatedImpact Float?
  targetScore     String?
  sprintGroup     String?
  status          String   @default("pending") // 'pending' | 'in_progress' | 'completed' | 'dismissed'
  snapshotId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project  Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content  Content?              @relation(fields: [contentId], references: [id], onDelete: SetNull)
  passage  Passage?              @relation(fields: [passageId], references: [id], onDelete: SetNull)
  snapshot ProjectScoreSnapshot? @relation(fields: [snapshotId], references: [id])

  @@index([projectId])
  @@index([contentId])
  @@map("recommendations")
}

// ─────────────────────────────────────────────
// JOB QUEUE
// ─────────────────────────────────────────────

model Job {
  id          String   @id @default(uuid())
  projectId   String?
  previewId   String?
  type        String   // 'preview_analysis' | 'discovery' | 'fetch_content' | ...
  status      String   @default("pending") // 'pending' | 'running' | 'completed' | 'failed'
  payload     Json?
  result      Json?
  error       String?
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  project Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  preview PreviewAnalysis? @relation(fields: [previewId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([projectId])
  @@index([previewId])
  @@map("jobs")
}

// ─────────────────────────────────────────────
// GSC INTEGRATION
// ─────────────────────────────────────────────

model GscConnection {
  id             String    @id @default(uuid())
  projectId      String    @unique // 1 connessione per progetto
  userId         String              // chi ha autorizzato

  // OAuth tokens (encrypted AES-256-GCM)
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime

  // GSC property
  propertyUrl    String?             // es. "https://www.example.com/" o "sc-domain:example.com"
  propertyType   String?             // "URL_PREFIX" | "DOMAIN"

  // Status
  status         String    @default("active") // "active" | "revoked" | "error"
  lastSyncAt     DateTime?
  lastSyncError  String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id])

  @@map("gsc_connections")
}

model GscQueryData {
  id          String   @id @default(uuid())
  projectId   String

  // Dati dalla GSC API
  query       String
  page        String?             // landing page URL
  country     String?             // ISO 3166-1 alpha-3
  device      String?             // "DESKTOP" | "MOBILE" | "TABLET"

  // Metriche
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0) // posizione media

  // Periodo
  dateStart   DateTime
  dateEnd     DateTime
  syncBatchId String              // traccia quale sync ha importato questi dati

  // Classificazione intento (calcolata dopo sync)
  intentType  String?             // "informational" | "comparative" | "decisional" | "navigational" | "conversational_ai"
  intentScore Float?              // confidenza 0-1
  isLongQuery Boolean  @default(false) // query 6+ parole (proxy AI query)

  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, query, country, device, dateStart, dateEnd])
  @@index([projectId, impressions(sort: Desc)])
  @@index([projectId, intentType])
  @@index([projectId, isLongQuery])
  @@map("gsc_query_data")
}

model IntentProfile {
  id               String   @id @default(uuid())
  projectId        String

  // Identificazione
  name             String
  slug             String
  description      String?

  // Caratteristiche derivate
  dominantIntent   String              // "informational" | "comparative" | "decisional"
  dominantDevice   String?             // "DESKTOP" | "MOBILE"
  dominantCountry  String?             // ISO alpha-3
  avgQueryLength   Float
  queryCount       Int
  totalImpressions Int

  // Pattern e query di esempio
  topPatterns      Json                // top 5 pattern (es. ["vs", "migliore", "come"])
  sampleQueries    Json                // 5 query esempio

  // Contesto per citation check
  contextPrompt    String?             // system prompt addendum per simulare questo profilo

  // Stato
  isActive         Boolean  @default(true)
  generatedAt      DateTime @default(now())

  project          Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  citationVariants CitationCheckVariant[]

  @@unique([projectId, slug])
  @@map("intent_profiles")
}

model CitationCheckVariant {
  id                String   @id @default(uuid())
  citationCheckId   String
  intentProfileId   String

  // Risultati della variante
  userCited         Boolean  @default(false)
  userCitedPosition Int?
  userCitedSegment  String?
  citedSources      Json?
  responseText      String?
  searchQueries     Json?

  // Contesto usato
  contextPromptUsed String

  createdAt         DateTime @default(now())

  citationCheck     CitationCheck @relation(fields: [citationCheckId], references: [id], onDelete: Cascade)
  intentProfile     IntentProfile @relation(fields: [intentProfileId], references: [id], onDelete: Cascade)

  @@unique([citationCheckId, intentProfileId])
  @@map("citation_check_variants")
}

model GscQuerySuggestion {
  id                   String   @id @default(uuid())
  projectId            String

  query                String
  reason               String
  intentType           String
  impressions          Int
  clicks               Int
  avgPosition          Float

  // Matching con query target esistenti
  matchedTargetQueryId String?
  similarityScore      Float?

  // Stato
  status               String   @default("pending") // "pending" | "accepted" | "dismissed"

  createdAt            DateTime @default(now())

  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, query])
  @@map("gsc_query_suggestions")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  projectId String?
  type      String   // 'analysis_complete' | 'score_change' | 'new_recommendations' | 'system'
  title     String
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
